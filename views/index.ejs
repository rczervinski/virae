<%
  // Category icon map for Material Symbols
  const categoryIconMap = {
    pdf: 'picture_as_pdf',
    image: 'image',
    gif: 'gif_box',
    audio: 'audiotrack',
    video: 'videocam',
    convert: 'swap_horiz',
    ai: 'auto_awesome'
  };

  // Subcategory order for PDF section
  const pdfSubcategoryOrder = [
    'Organizar',
    'Converter para PDF',
    'Converter de PDF',
    'Assinatura & Seguranca',
    'Visualizar & Editar',
    'Avancado'
  ];

  // Subcategory icons
  const subcategoryIconMap = {
    'Organizar': 'folder_managed',
    'Converter para PDF': 'input',
    'Converter de PDF': 'output',
    'Assinatura & Seguranca': 'shield_lock',
    'Visualizar & Editar': 'edit_document',
    'Avancado': 'build'
  };
%>
<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Virae — Todas as ferramentas para seus arquivos</title>
  <meta name="description" content="Ferramentas online gratuitas para PDF, imagem, GIF, audio e video. Mais de 80 ferramentas sem instalacao e sem cadastro.">

  <!-- Open Graph -->
  <meta property="og:title" content="Virae — Todas as ferramentas para seus arquivos">
  <meta property="og:description" content="Ferramentas online gratuitas para PDF, imagem, GIF, audio e video. Sem instalacao, sem cadastro.">
  <meta property="og:type" content="website">
  <meta property="og:locale" content="pt_BR">

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">

  <!-- Lottie Player -->
  <script src="https://unpkg.com/@lottiefiles/lottie-player@2.0.8/dist/lottie-player.js"></script>

  <!-- Stylesheets -->
  <link rel="stylesheet" href="/css/global.css">
  <link rel="stylesheet" href="/css/landing.css">
  <link rel="stylesheet" href="/css/components.css">

  <!-- JSON-LD: WebSite -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Virae",
    "url": "https://virae.com.br",
    "description": "Ferramentas online gratuitas para PDF, imagem, GIF, audio e video.",
    "potentialAction": {
      "@type": "SearchAction",
      "target": "https://virae.com.br/?q={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  }
  </script>
</head>
<body>

  <%- include('partials/nav') %>

  <main class="index-main">
    <!-- Hero Section -->
    <section class="index-hero">
      <div class="hero-glow"></div>
      <h1 class="index-h1 shimmer-title">Todas as ferramentas. Um so lugar.</h1>
      <p class="index-subtitle">Converta, comprima e edite seus arquivos direto no navegador.</p>

      <!-- Search -->
      <div class="index-search-wrapper">
        <span class="material-symbols-outlined index-search-icon">search</span>
        <input
          type="text"
          class="index-search"
          id="toolSearch"
          placeholder="Buscar ferramentas..."
          autocomplete="off"
        >
      </div>

      <!-- Stats -->
      <div class="index-stats">
        <span class="index-stat">80+ ferramentas</span>
        <span class="index-stat-sep">&bull;</span>
        <span class="index-stat">Sem instalacao</span>
        <span class="index-stat-sep">&bull;</span>
        <span class="index-stat">Arquivos apagados em 1h</span>
      </div>
    </section>

    <!-- Category Carousel -->
    <% if (typeof categories !== 'undefined' && typeof grouped !== 'undefined') { %>
      <div class="category-carousel-wrapper">
        <div class="category-carousel" id="categoryCarousel">
          <% categories.forEach(function(cat) { %>
            <% const catTools = grouped[cat.id]; %>
            <% if (catTools && catTools.length > 0) { %>
              <a href="#<%= cat.slug %>" class="carousel-pill" data-cat="<%= cat.id %>">
                <div class="carousel-pill-inner">
                  <span class="material-symbols-outlined carousel-pill-icon"><%= categoryIconMap[cat.id] || 'build' %></span>
                  <span class="carousel-pill-name"><%= cat.name %></span>
                  <span class="carousel-pill-count"><%= catTools.length %></span>
                </div>
              </a>
            <% } %>
          <% }); %>
        </div>
      </div>
    <% } %>

    <!-- Tool Categories -->
    <% if (typeof categories !== 'undefined' && typeof grouped !== 'undefined') { %>
      <% let catIndex = 0; %>
      <% categories.forEach(function(cat) { %>
        <% const catTools = grouped[cat.id]; %>
        <% if (catTools && catTools.length > 0) { %>
          <section class="category-section" id="<%= cat.slug %>" data-category="<%= cat.id %>">
            <div class="category-header">
              <span class="material-symbols-outlined category-icon" style="color: <%= cat.color %>;">
                <%= categoryIconMap[cat.id] || 'build' %>
              </span>
              <h2 class="category-title shimmer-title"><%= cat.name %></h2>
              <span class="category-count"><%= catTools.length %> ferramentas</span>
            </div>

            <% if (cat.id === 'pdf') { %>
              <%
                // Group PDF tools by subcategory
                const subGroups = {};
                catTools.forEach(function(t) {
                  const sub = t.subcategory || 'Outros';
                  if (!subGroups[sub]) subGroups[sub] = [];
                  subGroups[sub].push(t);
                });
              %>
              <div class="subcategory-container">
                <% pdfSubcategoryOrder.forEach(function(subName) { %>
                  <% const subTools = subGroups[subName]; %>
                  <% if (subTools && subTools.length > 0) { %>
                    <div class="subcategory-group">
                      <div class="subcategory-header">
                        <span class="material-symbols-outlined subcategory-icon" style="color: <%= cat.color %>;">
                          <%= subcategoryIconMap[subName] || 'category' %>
                        </span>
                        <h3 class="subcategory-title shimmer-title"><%= subName %></h3>
                        <span class="subcategory-count"><%= subTools.length %></span>
                      </div>
                      <div class="tools-grid">
                        <% subTools.forEach(function(t) { %>
                          <a href="/<%= t.slug %>" class="tool-card" data-name="<%= t.name.toLowerCase() %>" data-desc="<%= (t.description || '').toLowerCase() %>">
                            <div class="tool-card-icon" style="background-color: <%= cat.color %>15;">
                              <span class="material-symbols-outlined" style="color: <%= cat.color %>;">
                                <%= t.icon || categoryIconMap[cat.id] || 'build' %>
                              </span>
                            </div>
                            <div class="tool-card-text">
                              <span class="tool-card-name"><%= t.name %></span>
                              <span class="tool-card-desc"><%= t.description || '' %></span>
                            </div>
                            <% if (t.isPro) { %>
                              <span class="tool-card-badge badge-pro">PRO</span>
                            <% } %>
                            <% if (t.isAI) { %>
                              <span class="tool-card-badge badge-ai">IA</span>
                            <% } %>
                          </a>
                        <% }); %>
                      </div>
                    </div>
                  <% } %>
                <% }); %>
              </div>
            <% } else { %>
              <div class="tools-grid">
                <% catTools.forEach(function(t) { %>
                  <a href="/<%= t.slug %>" class="tool-card" data-name="<%= t.name.toLowerCase() %>" data-desc="<%= (t.description || '').toLowerCase() %>">
                    <div class="tool-card-icon" style="background-color: <%= cat.color %>15;">
                      <span class="material-symbols-outlined" style="color: <%= cat.color %>;">
                        <%= t.icon || categoryIconMap[cat.id] || 'build' %>
                      </span>
                    </div>
                    <div class="tool-card-text">
                      <span class="tool-card-name"><%= t.name %></span>
                      <span class="tool-card-desc"><%= t.description || '' %></span>
                    </div>
                    <% if (t.isPro) { %>
                      <span class="tool-card-badge badge-pro">PRO</span>
                    <% } %>
                    <% if (t.isAI) { %>
                      <span class="tool-card-badge badge-ai">IA</span>
                    <% } %>
                  </a>
                <% }); %>
              </div>
            <% } %>
          </section>

          <% catIndex++; %>
          <% if (catIndex === 2 || catIndex === 5) { %>
            <%- include('partials/ad-slot', { slotId: 'ad-cat-' + catIndex, adSlotId: '200000000' + catIndex, user: typeof user !== 'undefined' ? user : null }) %>
          <% } %>
        <% } %>
      <% }); %>
    <% } %>

    <!-- Pricing Section -->
    <section class="pricing-section">
      <h2 class="section-title shimmer-title">Gratis vs PRO</h2>
      <div class="pricing-grid">
        <!-- Free -->
        <div class="pricing-card">
          <div class="pricing-header">
            <h3 class="pricing-plan-name">Gratis</h3>
            <p class="pricing-price">R$ 0</p>
          </div>
          <ul class="pricing-features">
            <li class="pricing-feature">
              <span class="material-symbols-outlined pricing-check">check</span>
              Limite de 50MB por arquivo
            </li>
            <li class="pricing-feature">
              <span class="material-symbols-outlined pricing-check">check</span>
              Todas as ferramentas basicas
            </li>
            <li class="pricing-feature pricing-feature-disabled">
              <span class="material-symbols-outlined pricing-x">close</span>
              Contem anuncios
            </li>
            <li class="pricing-feature pricing-feature-disabled">
              <span class="material-symbols-outlined pricing-x">close</span>
              Limite de requisicoes
            </li>
            <li class="pricing-feature pricing-feature-disabled">
              <span class="material-symbols-outlined pricing-x">close</span>
              Sem ferramentas de IA avancadas
            </li>
          </ul>
        </div>

        <!-- PRO -->
        <div class="pricing-card pricing-card-pro">
          <div class="pricing-badge-popular">Mais popular</div>
          <div class="pricing-header">
            <h3 class="pricing-plan-name">PRO</h3>
            <p class="pricing-price">R$ 9,90<span class="pricing-period">/mes</span></p>
          </div>
          <ul class="pricing-features">
            <li class="pricing-feature">
              <span class="material-symbols-outlined pricing-check">check</span>
              Limite de 500MB por arquivo
            </li>
            <li class="pricing-feature">
              <span class="material-symbols-outlined pricing-check">check</span>
              Todas as ferramentas (incluindo IA)
            </li>
            <li class="pricing-feature">
              <span class="material-symbols-outlined pricing-check">check</span>
              Sem anuncios
            </li>
            <li class="pricing-feature">
              <span class="material-symbols-outlined pricing-check">check</span>
              Sem limites de requisicoes
            </li>
            <li class="pricing-feature">
              <span class="material-symbols-outlined pricing-check">check</span>
              Ferramentas de IA exclusivas
            </li>
          </ul>
          <a href="/auth/subscribe" class="btn-process pricing-cta">Assinar PRO</a>
        </div>
      </div>
    </section>
  </main>

  <%- include('partials/footer') %>

  <script src="/js/upload.js" defer></script>
  <script>
    document.addEventListener('DOMContentLoaded', function() {

      // ============================================================
      // Per-card glow (follows mouse within each card)
      // ============================================================
      var cards = document.querySelectorAll('.tool-card');
      cards.forEach(function(card) {
        card.addEventListener('mousemove', function(e) {
          var rect = card.getBoundingClientRect();
          var x = e.clientX - rect.left;
          var y = e.clientY - rect.top;
          card.style.setProperty('--mouse-x', x + 'px');
          card.style.setProperty('--mouse-y', y + 'px');
        });
      });

      // ============================================================
      // Tool Search Filter
      // ============================================================
      var searchInput = document.getElementById('toolSearch');
      if (!searchInput) return;

      searchInput.addEventListener('input', function() {
        var query = this.value.toLowerCase().trim();
        var allCards = document.querySelectorAll('.tool-card');
        var sections = document.querySelectorAll('.category-section');

        allCards.forEach(function(card) {
          var name = card.getAttribute('data-name') || '';
          var desc = card.getAttribute('data-desc') || '';
          if (!query || name.indexOf(query) !== -1 || desc.indexOf(query) !== -1) {
            card.style.display = '';
          } else {
            card.style.display = 'none';
          }
        });

        // Hide empty subcategory groups
        var subGroups = document.querySelectorAll('.subcategory-group');
        subGroups.forEach(function(group) {
          var visibleCards = group.querySelectorAll('.tool-card:not([style*="display: none"])');
          group.style.display = visibleCards.length === 0 ? 'none' : '';
        });

        // Hide empty category sections
        sections.forEach(function(section) {
          var visibleCards = section.querySelectorAll('.tool-card:not([style*="display: none"])');
          section.style.display = visibleCards.length === 0 ? 'none' : '';
        });
      });

      // ============================================================
      // Category Carousel Auto-Scroll
      // ============================================================
      var carousel = document.getElementById('categoryCarousel');
      if (carousel) {
        var scrollSpeed = 0.4;
        var scrollDirection = 1;
        var accumulator = 0;
        var autoScrollPaused = false;

        function autoScroll() {
          if (!autoScrollPaused) {
            accumulator += scrollSpeed;
            if (accumulator >= 1) {
              var px = Math.floor(accumulator);
              accumulator -= px;
              carousel.scrollLeft += px * scrollDirection;
              var maxScroll = carousel.scrollWidth - carousel.clientWidth;
              if (carousel.scrollLeft >= maxScroll - 1) {
                scrollDirection = -1;
              } else if (carousel.scrollLeft <= 1) {
                scrollDirection = 1;
              }
            }
          }
          requestAnimationFrame(autoScroll);
        }

        carousel.addEventListener('mouseenter', function() { autoScrollPaused = true; });
        carousel.addEventListener('mouseleave', function() { autoScrollPaused = false; });
        carousel.addEventListener('touchstart', function() { autoScrollPaused = true; }, { passive: true });
        carousel.addEventListener('touchend', function() {
          setTimeout(function() { autoScrollPaused = false; }, 2000);
        });

        requestAnimationFrame(autoScroll);
      }
    });
  </script>
</body>
</html>
